rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Connection Test Path
    match /test/connection {
      allow read: if true;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name']) 
        && data.uid == request.auth.uid 
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 200;
    }

    // Academic Work Validation
    function isValidWork(data) {
      return data.keys().hasAll(['title', 'ownerId', 'status'])
        && data.ownerId == request.auth.uid
        && data.title is string && data.title.size() <= 500
        && data.status in ['draft', 'generated', 'published']
        && (data.academicLevel == null || data.academicLevel in ['Ensino Médio', 'Universidade'])
        && (data.norms == null || data.norms in ['APA', 'ABNT', 'MLA']);
    }

    // --- Collections ---
    // AVISO: Regras relaxadas para TESTES. Voltar a ativar antes de produção.

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // 2. Academic Works Collection
    match /academicWorks/{workId} {
      allow read, write: if true;
    }
  }
}
